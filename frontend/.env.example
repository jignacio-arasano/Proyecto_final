# Plantilla de variables de entorno del frontend (Vite).
# Copiar a .env y completar los valores reales.

# URL del backend en producción (Oracle Cloud). Dejar vacío en desarrollo
# para usar el proxy de Vite (/api → localhost:8080).
VITE_API_URL=

# JWT estático de larga duración que el backend valida en cada request.
# Generar uno firmado con app.jwt.secret (HS256). NO commitear el valor real.
VITE_API_TOKEN=
